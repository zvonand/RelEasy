# RelEasy project config. See config.yaml.example in the source tree
# for the fully-documented reference covering every option.

# Unique slug identifying this project on this machine. Keys the
# per-project state file under
#   ${XDG_STATE_HOME:-~/.local/state}/releasy/<name>.state.yaml
# and (by default) the session file at
#   <config-dir>/<name>.session.yaml
# Allowed: A-Z a-z 0-9 . _ - (1-64 chars). Don't rename without
# `releasy adopt` (or just edit the state file path).
name: {{ name }}

# Where the local clone of the origin repo lives. Defaults to CWD.
# work_dir: /path/to/clone

# Push branches to origin and open PRs. Default: false (everything
# stays local until enabled).
# push: false

# Sequential mode: process the merged-time-sorted PR queue one PR per
# `releasy run` / `releasy continue` invocation. Each invocation either
# confirms the previous rebase PR was merged into target_branch and ports
# the next PR, or stops with an error. Default: false (batch mode).
# Incompatible with pr_sources.groups in the session file.
# sequential: false

# Optional explicit path to the session file (features + pr_sources).
# Relative paths resolve against this config's directory. Can also be
# overridden per-invocation with --session-file.
# Default: <config-dir>/<name>.session.yaml
# session_file: {{ name }}.session.yaml

origin:
  remote: <set me — https or ssh URL of the origin repo>
  remote_name: origin

# Short project identifier. Used in derived branch names like
# feature/<base>/<id>.
project: {{ project }}

# Explicit target/base branch. PRs are opened against this branch and
# port branches are created from origin/<target_branch>. Must already
# exist on origin.
target_branch: {{ target_branch }}

# ── PR processing policy ───────────────────────────────────────────
# Knobs that apply to every discovered PR / group. Lives here (not in
# the session file) because it's infrastructure — what to do with
# branches, when to retry, whether to open PRs — not *what* to port.
# All values shown below are defaults; omit the block to accept them.
# pr_policy:
#   if_exists: skip           # skip | recreate
#   auto_pr: true             # open a PR for every pushed port branch
#   retry_failed: true        # re-attempt conflicted entries on next run
#   recreate_closed_prs: false

# ai_resolve: Claude-driven conflict resolution. See config.yaml.example.
# ai_resolve:
#   enabled: false

# notifications: GitHub Project board sync. See config.yaml.example.
# notifications:
#   github_project: https://github.com/orgs/<org>/projects/<n>
